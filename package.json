{
  "name": "lollo176ita.github.io",
  "version": "2.5.0",
  "private": true,
  "homepage": "https://lollo176ita.github.io",
  "dependencies": {
    "framer-motion": "^12.19.1",
    "i18next": "^25.2.1",
    "react": "^19.1.0",
    "react-country-flag": "^3.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^15.5.3",
    "react-icons": "^5.5.0",
    "react-router-dom": "^7.6.2",
    "tailwindcss": "^3.4.15",
    "web-vitals": "^5.0.3"
  },
  "scripts": {
    "start": "vite",
    "build": "vite build",
    "build:prod": "vite build",
    "build:analyze": "ANALYZE=true vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "docs:sync": "node scripts/docs/sync-markdown.js",
    "stats": "node scripts/stats/generate-stats.js && cp src/data/project-stats.json public/project-stats.json",
    "stats:lighthouse": "node scripts/stats/lighthouse-stats.js",
    "prepare:content": "pnpm run docs:sync && pnpm run stats",
    "predeploy": "pnpm run prepare:content && pnpm run build:prod"
  },
  "eslintConfig": {
    "extends": [
      "./.eslintrc.json"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/ui": "^4.0.18",
    "autoprefixer": "^10.4.21",
    "eslint": "^10.0.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "execa": "^9.6.0",
    "glob": "^11.0.3",
    "jsdom": "^28.1.0",
    "lighthouse": "^12.6.1",
    "postcss": "^8.5.6",
    "serve": "^14.2.4",
    "vite": "^7.3.1",
    "vite-bundle-visualizer": "^1.2.1",
    "vite-plugin-compression2": "^2.5.0",
    "vite-prerender-plugin": "^0.5.12",
    "vitest": "^4.0.18"
  }
}
